---
// Fake BIOS-style boot sequence shown before the terminal
---

<section id="boot" class="boot" aria-label="System boot sequence">
  <pre class="boot-output" id="bootOutput"></pre>
  <button id="bootSkip" class="boot-skip" type="button" aria-label="Skip boot sequence">
    [ press ENTER / tap to skip ]
  </button>
</section>

<script>
  const lines = [
    { t: 'TermBIOS v4.7.26  (c) 1998-2026 dhani-corp', d: 60 },
    { t: 'CPU: Synthetic Neural Cortex @ 4.7 GHz', d: 40 },
    { t: 'Memory Test: 65536K OK', d: 60 },
    { t: 'Detecting drives ......... [OK]', d: 60 },
    { t: 'Loading kernel ........... [OK]', d: 80 },
    { t: 'Starting daemon: design-system ........ [OK]', d: 40 },
    { t: 'Starting daemon: react-renderer ....... [OK]', d: 40 },
    { t: 'Starting daemon: ai-copilot ........... [OK]', d: 40 },
    { t: 'Mounting /home/dhani .................. [OK]', d: 50 },
    { t: 'Establishing connection to portfolio... [OK]', d: 80 },
    { t: '', d: 80 },
    { t: '> welcome, visitor.', d: 200 },
    { t: '> type `help` to begin, or use the quick buttons below.', d: 200 },
  ];

  const bootEl = document.getElementById('boot');
  const bootOutput = document.getElementById('bootOutput');
  const bootSkip = document.getElementById('bootSkip');
  let done = false;

  const sleep = (ms: number) => new Promise<void>((r) => setTimeout(r, ms));

  function finish() {
    if (done) return;
    done = true;
    if (bootEl) bootEl.style.display = 'none';
    document.dispatchEvent(new CustomEvent('boot:done'));
  }

  async function run() {
    if (!bootOutput) return finish();
    bootOutput.textContent = '';
    for (const line of lines) {
      if (done) return;
      bootOutput.textContent += line.t + '\n';
      await sleep(line.d);
    }
    await sleep(400);
    finish();
  }

  bootSkip?.addEventListener('click', finish);

  function keyHandler(e: KeyboardEvent) {
    if (!done && (e.key === 'Enter' || e.key === ' ' || e.key === 'Escape')) {
      e.preventDefault();
      finish();
    }
  }
  document.addEventListener('keydown', keyHandler);

  // Kick off after a tick so the rest of the page mounts
  requestAnimationFrame(() => run());
</script>
