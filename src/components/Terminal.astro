---
import { RESUME } from '../data/resume';

const QUICK_CMDS = [
  'help',
  'whoami',
  'experience',
  'skills',
  'timeline',
  'projects',
  'education',
  'awards',
  'contact',
  'neofetch',
  'matrix',
  'clear',
];

// Serialize resume so the client script can use it
const resumeJson = JSON.stringify(RESUME);
---

<main id="terminal" class="terminal" hidden>
  <header class="term-bar">
    <div class="term-bar-left">
      <span class="dot dot-r" aria-hidden="true"></span>
      <span class="dot dot-y" aria-hidden="true"></span>
      <span class="dot dot-g" aria-hidden="true"></span>
    </div>
    <div class="term-bar-title">dhani@portfolio: ~ — zsh — 96×32</div>
    <div class="term-bar-right">
      <button class="bar-btn" data-theme-set="phosphor" title="Phosphor green theme">P</button>
      <button class="bar-btn" data-theme-set="amber" title="Amber CRT theme">A</button>
      <button class="bar-btn" data-theme-set="ice" title="Ice blue theme">I</button>
      <button class="bar-btn" data-theme-set="synth" title="Synthwave theme">S</button>
    </div>
  </header>

  <div class="term-body" id="termBody">
    <div id="termOutput" class="term-output" aria-live="polite"></div>

    <div class="term-input-line" id="termInputLine">
      <span class="prompt">
        <span class="prompt-user">dhani</span><span class="prompt-at">@</span><span
          class="prompt-host">portfolio</span><span class="prompt-colon">:</span><span
          class="prompt-path">~</span><span class="prompt-sym">$</span>
      </span>
      <input
        id="termInput"
        class="term-input"
        type="text"
        autocomplete="off"
        autocorrect="off"
        autocapitalize="off"
        spellcheck="false"
        aria-label="Terminal command input"
      />
      <span class="cursor" id="cursor">█</span>
    </div>
  </div>

  <footer class="term-foot">
    <div class="quickbar" aria-label="Quick commands">
      {QUICK_CMDS.map((c) => <button class="qbtn" data-cmd={c}>{c}</button>)}
    </div>
    <div class="hint">
      tip: try typing <kbd>help</kbd>, or <kbd>↑</kbd>/<kbd>↓</kbd> for history · <kbd>Tab</kbd> to autocomplete
    </div>
  </footer>
</main>

<script is:inline define:vars={{ resumeJson }}>
  (function () {
    'use strict';

    /** @type {any} */
    const RESUME = JSON.parse(resumeJson);

    const NAME_ART =
      '\n' +
      ' ███████╗   ██████╗ ██╗  ██╗ █████╗ ███╗   ██╗██╗\n' +
      ' ██╔════╝   ██╔══██╗██║  ██║██╔══██╗████╗  ██║██║\n' +
      ' █████╗     ██║  ██║███████║███████║██╔██╗ ██║██║\n' +
      ' ██╔══╝     ██║  ██║██╔══██║██╔══██║██║╚██╗██║██║\n' +
      ' ██║██╗  ██╗██████╔╝██║  ██║██║  ██║██║ ╚████║██║\n' +
      ' ╚═╝╚═╝  ╚═╝╚═════╝ ╚═╝  ╚═╝╚═╝  ╚═╝╚═╝  ╚═══╝╚═╝\n' +
      '                       a c h m a d\n';

    const PORTRAIT =
      "\n" +
      "        .---.\n" +
      "       / o o \\\n" +
      "       \\  ^  /\n" +
      "        '---'\n" +
      "       /|   |\\\n" +
      "      / | x | \\\n" +
      "        |___|\n" +
      "        |   |\n" +
      "        |___|\n" +
      "       _|   |_\n";

    const $ = (sel) => document.querySelector(sel);
    const termEl = $('#terminal');
    const termBody = $('#termBody');
    const termOutput = $('#termOutput');
    const termInput = $('#termInput');
    const cursorEl = $('#cursor');

    const esc = (s) =>
      String(s).replace(
        /[&<>"']/g,
        (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c]
      );

    function append(html, cls = '') {
      const div = document.createElement('div');
      div.className = ('line fade-in ' + cls).trim();
      div.innerHTML = html;
      termOutput.appendChild(div);
      scroll();
      return div;
    }
    function scroll() {
      termBody.scrollTop = termBody.scrollHeight;
    }

    function showBanner() {
      append('<pre class="ascii-art">' + esc(NAME_ART) + '</pre>');
      append('<span class="ln-muted">────────────────────────────────────────────────────────────</span>');
      append(
        '<span class="ln-h2">' +
          esc(RESUME.title) +
          '</span> <span class="ln-muted">·</span> <span class="ln-info">' +
          esc(RESUME.location) +
          '</span>'
      );
      append('<span class="ln-muted">"' + esc(RESUME.summary) + '"</span>');
      append(' ');
      append(
        '<span class="ln-ok">★</span> type <kbd>help</kbd> to see commands · <kbd>Tab</kbd> autocompletes · <kbd>↑/↓</kbd> for history · <kbd>theme</kbd> switches palette'
      );
      append(' ');
    }

    // ---------- COMMANDS ----------
    const COMMANDS = {};
    function defineCmd(name, def) {
      COMMANDS[name] = def;
      if (def.aliases) def.aliases.forEach((a) => (COMMANDS[a] = def));
    }

    defineCmd('help', {
      aliases: ['?', 'man', 'commands'],
      run() {
        const rows = [
          ['help', 'show this message'],
          ['whoami', 'short summary of who I am'],
          ['about', 'longer bio'],
          ['experience', 'work history (alias: exp, work)'],
          ['timeline', 'visual career timeline'],
          ['skills', 'skill stack with phosphor bars'],
          ['projects', 'highlighted projects'],
          ['education', 'education history'],
          ['awards', 'honors & awards'],
          ['languages', 'spoken languages'],
          ['contact', 'how to reach me'],
          ['neofetch', 'system info card'],
          ['ls', 'list portfolio sections'],
          ['cat <file>', 'read a section (e.g. cat about.md)'],
          ['theme <name>', 'switch palette: phosphor | amber | ice | synth'],
          ['matrix', 'enter the matrix (toggle background rain)'],
          ['glitch', 'oh no'],
          ['coffee', '☕'],
          ['sudo', 'try it'],
          ['date', 'show current date/time'],
          ['history', 'show command history'],
          ['clear', 'wipe the terminal (alias: cls)'],
          ['exit', 'logout (not really)'],
        ];
        const w = Math.max.apply(
          null,
          rows.map((r) => r[0].length)
        );
        append('<span class="ln-h">AVAILABLE COMMANDS</span>');
        rows.forEach((r) => {
          const pad = ' '.repeat(w - r[0].length + 2);
          append(
            '  <span class="ln-ok">' +
              esc(r[0]) +
              '</span>' +
              pad +
              '<span class="ln-muted">' +
              esc(r[1]) +
              '</span>'
          );
        });
      },
    });

    defineCmd('whoami', {
      aliases: ['me'],
      run() {
        append('<span class="ln-h">WHOAMI</span>');
        append(
          '<span class="ln-h2">' +
            esc(RESUME.name) +
            '</span> — <span class="ln-info">' +
            esc(RESUME.title) +
            '</span>'
        );
        append('<span class="ln-muted">' + esc(RESUME.location) + '</span>');
        append(' ');
        append(esc(RESUME.summary));
      },
    });

    defineCmd('about', {
      run() {
        append('<span class="ln-h">ABOUT</span>');
        append("Frontend engineer with a designer's eye and an AI tinkerer's curiosity.");
        append(
          'Past 8+ years across <span class="ln-h2">Tokopedia</span>, <span class="ln-h2">99 Group</span>, and now <span class="ln-h2">Omni HR</span>.'
        );
        append('I like turning legacy codebases into tidy systems, mentoring engineers,');
        append('and squeezing performance out of pages that millions of people use.');
        append(' ');
        append(
          'Outside the editor: UI/UX design, languages (en/fr/id), and the occasional pitch competition. <span class="ln-muted">(yes, won a few.)</span>'
        );
      },
    });

    defineCmd('experience', {
      aliases: ['work', 'exp', 'jobs'],
      run() {
        append('<span class="ln-h">EXPERIENCE</span>');
        RESUME.experience.forEach((e) => {
          const bullets = e.bullets.map((b) => '<li>' + esc(b) + '</li>').join('');
          append(
            '<div class="card">' +
              '<div><span class="role">' +
              esc(e.role) +
              '</span> <span class="ln-muted">@</span> <span class="org">' +
              esc(e.org) +
              '</span></div>' +
              '<div class="when">' +
              esc(e.when) +
              ' · ' +
              esc(e.loc) +
              '</div>' +
              '<ul class="bullets">' +
              bullets +
              '</ul>' +
              '</div>'
          );
        });
      },
    });

    defineCmd('timeline', {
      aliases: ['tl'],
      run() {
        append('<span class="ln-h">CAREER TIMELINE</span>');
        append(
          '<span class="ln-muted">each block ≈ time at role · phosphor bars are role span</span>'
        );
        append(' ');

        const minY = 2014;
        const maxY = 2026.5;
        const span = maxY - minY;
        const W = 48;

        const years = [];
        for (let y = minY; y <= maxY; y += 2) years.push(y);
        let header = ' '.repeat(W + 2);
        years.forEach((y) => {
          const pos = Math.round(((y - minY) / span) * W);
          const label = String(Math.floor(y));
          for (let i = 0; i < label.length; i++) {
            const idx = pos + i;
            if (idx < header.length)
              header = header.substring(0, idx) + label[i] + header.substring(idx + 1);
          }
        });
        append('<div class="timeline"><span class="tl-when">' + esc(header) + '</span></div>');
        append(
          '<div class="timeline"><span class="tl-when">' +
            esc('└' + '─'.repeat(W) + '┘') +
            '</span></div>'
        );

        const sorted = RESUME.experience.slice().sort((a, b) => a.startY - b.startY);
        sorted.forEach((e) => {
          const start = Math.round(((e.startY - minY) / span) * W);
          const end = Math.round(((e.endY - minY) / span) * W);
          const barLen = Math.max(1, end - start);
          const pad = ' '.repeat(Math.max(0, start));
          const bar = '█'.repeat(barLen);
          const orgShort = e.org.length > 16 ? e.org.slice(0, 14) + '…' : e.org;
          append(
            '<div class="timeline">' +
              esc(pad) +
              '<span class="tl-bar">' +
              esc(bar) +
              '</span>  <span class="tl-org">' +
              esc(orgShort) +
              '</span> <span class="tl-when">— ' +
              esc(e.role) +
              '</span></div>'
          );
        });
        append(' ');
        append(
          '<span class="ln-muted">tip: <kbd>experience</kbd> shows the full details for each role.</span>'
        );
      },
    });

    defineCmd('skills', {
      aliases: ['stack'],
      run() {
        append('<span class="ln-h">SKILL STACK</span>');
        const wrap = document.createElement('div');
        wrap.className = 'skill-grid line fade-in';
        RESUME.skills.forEach((group) => {
          const itemHtml = group.items
            .map((pair) => {
              const on = '█'.repeat(pair[1]);
              const off = '░'.repeat(10 - pair[1]);
              return (
                '<div class="bar">' +
                '<span class="name">' +
                esc(pair[0]) +
                '</span>' +
                '<span class="meter">' +
                on +
                '<span class="off">' +
                off +
                '</span></span>' +
                '</div>'
              );
            })
            .join('');
          wrap.innerHTML +=
            '<div class="skill-group"><h4>// ' + esc(group.name) + '</h4>' + itemHtml + '</div>';
        });
        termOutput.appendChild(wrap);
        append(
          '<span class="ln-muted">top skills: ' +
            RESUME.topSkills
              .map((s) => '<span class="ln-tag">' + esc(s) + '</span>')
              .join('') +
            '</span>'
        );
        scroll();
      },
    });

    defineCmd('projects', {
      aliases: ['proj'],
      run() {
        append('<span class="ln-h">SELECTED PROJECTS</span>');
        RESUME.projects.forEach((p) => {
          append(
            '  <span class="ln-ok">▸</span> <span class="ln-h2">' +
              esc(p[0]) +
              '</span>'
          );
          append('     <span class="ln-muted">' + esc(p[1]) + '</span>');
        });
      },
    });

    defineCmd('education', {
      aliases: ['edu'],
      run() {
        append('<span class="ln-h">EDUCATION</span>');
        RESUME.education.forEach((e) => {
          append(
            '  <span class="ln-ok">◉</span> <span class="ln-h2">' +
              esc(e.school) +
              '</span> — <span class="ln-muted">' +
              esc(e.degree) +
              '</span>'
          );
        });
      },
    });

    defineCmd('awards', {
      aliases: ['honors'],
      run() {
        append('<span class="ln-h">HONORS & AWARDS</span>');
        RESUME.awards.forEach((a) => {
          append(
            '  <span class="ln-bar">' +
              esc(a.year) +
              '</span>  <span class="ln-h2">' +
              esc(a.title) +
              '</span> — <span class="ln-info">' +
              esc(a.detail) +
              '</span>'
          );
        });
        append(' ');
        append(
          '<span class="ln-muted">certifications: ' +
            RESUME.certifications.join(', ') +
            '</span>'
        );
      },
    });

    defineCmd('languages', {
      aliases: ['langs'],
      run() {
        append('<span class="ln-h">LANGUAGES</span>');
        RESUME.languages.forEach((l) =>
          append('  <span class="ln-ok">✦</span> ' + esc(l))
        );
      },
    });

    defineCmd('contact', {
      aliases: ['connect', 'reach'],
      run() {
        const c = RESUME.contact;
        append('<span class="ln-h">CONTACT</span>');
        append(
          '<div class="contact-list">' +
            '<a href="mailto:' +
            esc(c.email) +
            '">✉ ' +
            esc(c.email) +
            '</a>' +
            '<a href="' +
            esc(c.linkedin) +
            '" target="_blank" rel="noopener">in/ ' +
            esc(c.linkedin.split('/').pop()) +
            '</a>' +
            '<a href="' +
            esc(c.github) +
            '" target="_blank" rel="noopener">⌨ github/' +
            esc(c.github.split('/').pop()) +
            '</a>' +
            '<a href="' +
            esc(c.behance) +
            '" target="_blank" rel="noopener">✎ behance</a>' +
            '</div>'
        );
        append('<span class="ln-muted">mobile: ' + esc(c.mobile) + '</span>');
      },
    });

    defineCmd('neofetch', {
      run() {
        const c = RESUME.contact;
        append(
          '<div class="neofetch">' +
            '<pre class="logo">' +
            esc(PORTRAIT) +
            '</pre>' +
            '<div class="info">' +
            '<div class="row"><span class="k">' +
            esc(RESUME.handle) +
            '</span><span class="sep">@</span><span class="k">portfolio</span></div>' +
            '<div class="row"><span class="sep">────────────────────</span></div>' +
            '<div class="row"><span class="k">Name</span><span class="sep">: </span>' +
            esc(RESUME.name) +
            '</div>' +
            '<div class="row"><span class="k">Role</span><span class="sep">: </span>' +
            esc(RESUME.title) +
            '</div>' +
            '<div class="row"><span class="k">Host</span><span class="sep">: </span>Omni HR · Singapore</div>' +
            '<div class="row"><span class="k">Uptime</span><span class="sep">: </span>~8 years in industry</div>' +
            '<div class="row"><span class="k">Shell</span><span class="sep">: </span>JetBrains Mono / phosphor</div>' +
            '<div class="row"><span class="k">Editor</span><span class="sep">: </span>VS Code · vim motions on a good day</div>' +
            '<div class="row"><span class="k">Stack</span><span class="sep">: </span>React · Next.js · TypeScript · Flutter</div>' +
            '<div class="row"><span class="k">Locale</span><span class="sep">: </span>en_US · fr_FR · id_ID</div>' +
            '<div class="row"><span class="k">Email</span><span class="sep">: </span><a href="mailto:' +
            esc(c.email) +
            '">' +
            esc(c.email) +
            '</a></div>' +
            '</div>' +
            '</div>'
        );
      },
    });

    defineCmd('ls', {
      run() {
        const files = [
          'about.md',
          'experience.md',
          'timeline.txt',
          'skills.json',
          'projects.md',
          'education.md',
          'awards.md',
          'contact.vcf',
          'secrets/',
        ];
        const cls = [
          'ln-ok',
          'ln-ok',
          'ln-info',
          'ln-h2',
          'ln-ok',
          'ln-ok',
          'ln-h2',
          'ln-info',
          'ln-warn',
        ];
        const out = files
          .map(
            (f, i) =>
              '<span class="' +
              cls[i] +
              '">' +
              esc(f.padEnd(16)) +
              '</span>'
          )
          .join('');
        append(out);
      },
    });

    defineCmd('cat', {
      run(args) {
        const file = (args[0] || '').toLowerCase();
        const map = {
          'about.md': 'about',
          'experience.md': 'experience',
          'timeline.txt': 'timeline',
          'skills.json': 'skills',
          'projects.md': 'projects',
          'education.md': 'education',
          'awards.md': 'awards',
          'contact.vcf': 'contact',
        };
        if (!file)
          return append(
            '<span class="ln-err">cat: missing operand. try: <kbd>cat about.md</kbd></span>'
          );
        if (file.indexOf('secrets') === 0)
          return append(
            '<span class="ln-err">cat: ' + esc(file) + ': Permission denied — nice try.</span>'
          );
        const cmd = map[file];
        if (!cmd)
          return append(
            '<span class="ln-err">cat: ' + esc(file) + ': No such file. try <kbd>ls</kbd>.</span>'
          );
        execute(cmd);
      },
    });

    defineCmd('theme', {
      run(args) {
        const name = (args[0] || '').toLowerCase();
        const valid = ['phosphor', 'amber', 'ice', 'synth'];
        if (!name) {
          append(
            '<span class="ln-h">CURRENT THEME</span> <span class="ln-h2">' +
              document.body.dataset.theme +
              '</span>'
          );
          append(
            '<span class="ln-muted">usage: <kbd>theme &lt;' +
              valid.join(' | ') +
              '&gt;</kbd></span>'
          );
          return;
        }
        if (valid.indexOf(name) === -1)
          return append(
            '<span class="ln-err">theme: unknown "' +
              esc(name) +
              '". choose: ' +
              valid.join(', ') +
              '</span>'
          );
        setTheme(name);
        append(
          '<span class="ln-ok">→ theme set to <span class="ln-h2">' + esc(name) + '</span></span>'
        );
      },
    });

    defineCmd('matrix', {
      run() {
        append('<span class="ln-ok">→ wake up, Neo...</span>');
        triggerMatrixBurst();
      },
    });

    defineCmd('glitch', {
      run() {
        append(
          '<span class="glitch" data-text="SYSTEM CORRUPTION DETECTED">SYSTEM CORRUPTION DETECTED</span>'
        );
        append("<span class=\"ln-muted\">just kidding. everything's fine.</span>");
      },
    });

    defineCmd('coffee', {
      run() {
        append(
          '<pre class="ascii-art">' +
            esc(
              "       (  )   (   )  )\n" +
                "        ) (   )  (  (\n" +
                "        ( )  (    ) )\n" +
                "        _____________\n" +
                "       <_____________>  ___\n" +
                "       |             |/ _ \\\n" +
                "       |               | | |\n" +
                "       |               |_| |\n" +
                "    ___|             |\\___/\n" +
                "   /    \\___________/    \\\n" +
                "   \\_____________________/"
            ) +
            '</pre>'
        );
        append(
          '<span class="ln-muted">brewed at ' +
            new Date().toLocaleTimeString() +
            '. stay caffeinated.</span>'
        );
      },
    });

    defineCmd('sudo', {
      run(args) {
        if (args.length)
          append(
            '<span class="ln-warn">[sudo] password for dhani: </span><span class="ln-err">******</span>'
          );
        append(
          '<span class="ln-err">dhani is not in the sudoers file. This incident will be reported.</span>'
        );
      },
    });

    defineCmd('date', {
      run() {
        append('<span class="ln-info">' + esc(new Date().toString()) + '</span>');
      },
    });

    defineCmd('history', {
      run() {
        if (!history.length) return append('<span class="ln-muted">(history is empty)</span>');
        history.forEach((c, i) =>
          append(
            '  <span class="ln-muted">' +
              String(i + 1).padStart(4) +
              '</span>  ' +
              esc(c)
          )
        );
      },
    });

    defineCmd('clear', {
      aliases: ['cls'],
      run() {
        termOutput.innerHTML = '';
      },
    });

    defineCmd('exit', {
      aliases: ['logout', 'quit'],
      run() {
        append(
          "<span class=\"ln-warn\">exit: nice try, but you can't leave. the portfolio loves you.</span>"
        );
      },
    });

    defineCmd('hello', {
      aliases: ['hi'],
      run() {
        append('<span class="ln-ok">→ hello there 👋</span>');
        append('<span class="ln-muted">try <kbd>whoami</kbd> or <kbd>experience</kbd></span>');
      },
    });

    defineCmd('echo', {
      run(args) {
        append(esc(args.join(' ')));
      },
    });

    defineCmd('rm', {
      run(args) {
        if (args.indexOf('-rf') !== -1 && (args.indexOf('/') !== -1 || args.indexOf('*') !== -1)) {
          append('<span class="ln-err">⚠  PERMISSION DENIED  ⚠</span>');
          append("<span class=\"ln-muted\">that's not the kind of engineer I am.</span>");
        } else {
          append(
            '<span class="ln-muted">rm: nothing to remove. this is a portfolio, not a filesystem.</span>'
          );
        }
      },
    });

    defineCmd('hire', {
      aliases: ['hireme'],
      run() {
        append('<span class="ln-h">★ THANKS FOR CONSIDERING ★</span>');
        append('open to interesting frontend + AI-adjacent conversations.');
        append(
          'fastest path: <a href="mailto:' +
            RESUME.contact.email +
            '">' +
            RESUME.contact.email +
            '</a>'
        );
      },
    });

    // ---------- RUNNER ----------
    const history = [];
    let historyIdx = -1;

    function execute(input) {
      const raw = String(input || '').trim();
      if (!raw) {
        echoPrompt('');
        return;
      }
      history.push(raw);
      historyIdx = history.length;
      echoPrompt(raw);

      const parts = raw.split(/\s+/);
      const cmd = parts.shift().toLowerCase();
      const c = COMMANDS[cmd];
      if (!c) {
        append('<span class="ln-err">command not found: ' + esc(cmd) + '</span>');
        append('<span class="ln-muted">type <kbd>help</kbd> to see what works.</span>');
        return;
      }
      try {
        c.run(parts);
      } catch (err) {
        append('<span class="ln-err">unexpected error: ' + esc(err.message || err) + '</span>');
      }
    }

    function echoPrompt(text) {
      append(
        '<span class="ln-cmd"><span class="echo-prompt"><span class="prompt-user">dhani</span><span class="prompt-at">@</span><span class="prompt-host">portfolio</span><span class="prompt-colon">:</span><span class="prompt-path">~</span><span class="prompt-sym">$</span></span> ' +
          esc(text) +
          '</span>'
      );
    }

    // ---------- INPUT ----------
    function syncCursor() {
      if (cursorEl)
        cursorEl.style.visibility = document.activeElement === termInput ? 'visible' : 'hidden';
    }

    termInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') {
        const v = termInput.value;
        termInput.value = '';
        execute(v);
      } else if (e.key === 'ArrowUp') {
        if (!history.length) return;
        e.preventDefault();
        historyIdx = Math.max(0, historyIdx - 1);
        termInput.value = history[historyIdx] || '';
      } else if (e.key === 'ArrowDown') {
        if (!history.length) return;
        e.preventDefault();
        historyIdx = Math.min(history.length, historyIdx + 1);
        termInput.value = history[historyIdx] || '';
      } else if (e.key === 'Tab') {
        e.preventDefault();
        const v = termInput.value.trim();
        if (!v) return;
        const names = Object.keys(COMMANDS).filter((n) => n.indexOf(v) === 0);
        if (names.length === 1) {
          termInput.value = names[0];
        } else if (names.length > 1) {
          append('<span class="ln-muted">' + names.map(esc).join('  ') + '</span>');
        }
      } else if (e.ctrlKey && e.key.toLowerCase() === 'l') {
        e.preventDefault();
        termOutput.innerHTML = '';
      } else if (e.ctrlKey && e.key.toLowerCase() === 'c') {
        e.preventDefault();
        echoPrompt(termInput.value);
        append('<span class="ln-muted">^C</span>');
        termInput.value = '';
      }
    });

    document.addEventListener('click', (e) => {
      if (termEl.hidden) return;
      const target = e.target;
      if (target.closest && target.closest('.qbtn, .bar-btn, a, button, kbd')) return;
      termInput.focus();
    });
    termInput.addEventListener('focus', syncCursor);
    termInput.addEventListener('blur', syncCursor);

    document.querySelectorAll('.qbtn').forEach((b) =>
      b.addEventListener('click', () => {
        execute(b.dataset.cmd);
        termInput.focus();
      })
    );

    document.querySelectorAll('[data-theme-set]').forEach((b) =>
      b.addEventListener('click', () => setTheme(b.dataset.themeSet))
    );

    function setTheme(name) {
      document.body.dataset.theme = name;
      try {
        localStorage.setItem('portfolio-theme', name);
      } catch (_) {}
    }
    try {
      const saved = localStorage.getItem('portfolio-theme');
      if (saved) setTheme(saved);
    } catch (_) {}

    function triggerMatrixBurst() {
      const overlay = document.createElement('div');
      overlay.className = 'matrix-burst';
      const canvas = document.createElement('canvas');
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
      canvas.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;';
      overlay.appendChild(canvas);
      const hint = document.createElement('div');
      hint.className = 'hint-text';
      hint.textContent = 'click anywhere to exit';
      overlay.appendChild(hint);
      document.body.appendChild(overlay);

      const ctx = canvas.getContext('2d');
      const localCols = Math.floor(canvas.width / 16);
      const localDrops = new Array(localCols).fill(0).map(() => Math.random() * -50);
      const color =
        getComputedStyle(document.body).getPropertyValue('--accent').trim() || '#00ff7a';
      const chars =
        'アイウエオカキクケコサシスセソタチツテトナニヌネノ0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ<>{}[]=+/*-_'.split(
          ''
        );
      let raf = 0;
      function tick() {
        ctx.fillStyle = 'rgba(6,10,6,0.08)';
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        ctx.fillStyle = color;
        ctx.font = '16px JetBrains Mono, monospace';
        for (let i = 0; i < localCols; i++) {
          const ch = chars[Math.floor(Math.random() * chars.length)];
          ctx.fillText(ch, i * 16, localDrops[i] * 16);
          if (localDrops[i] * 16 > canvas.height && Math.random() > 0.97) localDrops[i] = 0;
          localDrops[i]++;
        }
        raf = requestAnimationFrame(tick);
      }
      tick();
      const close = () => {
        cancelAnimationFrame(raf);
        overlay.remove();
      };
      overlay.addEventListener('click', close);
      setTimeout(() => {
        if (overlay.parentNode) close();
      }, 5500);
    }

    // ---------- START ----------
    function start() {
      termEl.hidden = false;
      showBanner();
      termInput.focus();
    }

    document.addEventListener('boot:done', start, { once: true });

    document.addEventListener('keydown', (e) => {
      if (termEl.hidden) return;
      if (e.target === termInput) return;
      if (e.key.length === 1 && !e.ctrlKey && !e.metaKey && !e.altKey) {
        termInput.focus();
      }
    });
  })();
</script>
