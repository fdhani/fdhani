---
import Layout from '../layouts/Layout.astro';
import { RESUME } from '../data/resume';

const base = import.meta.env.BASE_URL;
---

<Layout activeNav="home">
  <main class="page">
    <div class="container">
      <!-- ============================ HERO ============================ -->
      <section class="hero">
        <h1>
          Hi, I'm Dhani a<br />
          <span class="role-rotate accent" aria-label="Front-end engineer, Product engineer, or Full-stack engineer">
            <span class="role-rotate-inner" aria-hidden="true">
              <span>Front-end engineer</span>
              <span>Product engineer</span>
              <span>Full-stack engineer</span>
              <span>Front-end engineer</span>
            </span>
          </span>
        </h1>
        <p class="lead">
          8 years of experience, and I still get excited when something just works.
          I build with React, TypeScript, Flutter, across web and mobile, with a
          full-stack mindset and a soft obsession with performance. I'm the kind
          of engineer who questions the brief before touching the keyboard and
          pixel-matches the Figma when it counts. Remote by choice, collaborative
          by nature.
        </p>

        <div class="cta-row">
          <a class="cta-primary" href={`${base}about-me/`}>
            <span>Learn more</span>
            <span class="arrow" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12" />
                <polyline points="12 5 19 12 12 19" />
              </svg>
            </span>
          </a>
        </div>

        <div class="meta">
          <span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
              <circle cx="12" cy="10" r="3" />
            </svg>
            West Java, Indonesia
          </span>
          <span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="10" />
              <polyline points="12 6 12 12 16 14" />
            </svg>
            8+ years in frontend
          </span>
        </div>

        <div class="socials">
          <a href={`mailto:${RESUME.contact.email}`}>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
              <polyline points="22,6 12,13 2,6" />
            </svg>
            email
          </a>
          <a href={RESUME.contact.github} target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.55v-2.01c-3.2.7-3.88-1.37-3.88-1.37-.52-1.33-1.28-1.69-1.28-1.69-1.05-.72.08-.71.08-.71 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.73-1.55-2.55-.29-5.24-1.28-5.24-5.69 0-1.26.45-2.28 1.19-3.09-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.79 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.24 2.76.12 3.05.74.81 1.19 1.84 1.19 3.09 0 4.42-2.69 5.4-5.26 5.68.41.36.78 1.06.78 2.14v3.17c0 .31.21.66.79.55A11.52 11.52 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5z" />
            </svg>
            github
          </a>
          <a href={RESUME.contact.linkedin} target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.45 20.45h-3.55v-5.56c0-1.32-.02-3.03-1.85-3.03-1.85 0-2.14 1.45-2.14 2.94v5.65H9.36V9h3.41v1.56h.05c.47-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.22.79 24 1.77 24h20.45C23.2 24 24 23.22 24 22.27V1.73C24 .77 23.2 0 22.22 0z" />
            </svg>
            linkedin
          </a>
        </div>
      </section>

      <!-- ============================ BLOG TEASER ============================ -->
      <section class="section reveal">
        <div class="section-head">
          <h2>writing</h2>
          <a class="more" href={`${base}blog/`}>visit blog →</a>
        </div>
        <div class="blog-empty">
          <span class="icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="4 17 10 11 4 5" />
              <line x1="12" y1="19" x2="20" y2="19" />
            </svg>
          </span>
          <h3>
            Coming soon<span class="cursor" aria-hidden="true" />
          </h3>
          <p>
            I'm drafting my first posts on frontend performance and
            AI-assisted dev. Check back shortly.
          </p>
        </div>
      </section>
    </div>
  </main>
</Layout>
