---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const base = import.meta.env.BASE_URL;

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: '2-digit' });
---

<Layout
  title="Blog — F. Dhani Achmad"
  description="Notes on frontend engineering, performance, design systems, and AI-assisted development by F. Dhani Achmad."
  activeNav="blog"
>
  <main class="page">
    <div class="container">
      <a class="nav-back" href={base}>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="19" y1="12" x2="5" y2="12" />
          <polyline points="12 19 5 12 12 5" />
        </svg>
        ../
      </a>

      <header class="page-intro">
        <h1>Blog</h1>
        <p class="lead">
          Short notes on frontend, performance, design systems, and AI-assisted
          dev workflows.
        </p>
      </header>

      {
        posts.length === 0 ? (
          <div class="blog-empty reveal">
            <span class="icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="4 17 10 11 4 5" />
                <line x1="12" y1="19" x2="20" y2="19" />
              </svg>
            </span>
            <h3>
              Coming soon<span class="cursor" aria-hidden="true" />
            </h3>
            <p>
              I'm drafting my first posts on frontend performance and
              AI-assisted dev. Check back shortly.
            </p>
          </div>
        ) : (
          <section class="reveal">
            <div class="post-list">
              {posts.map((post) => (
                <a class="post-row" href={`${base}blog/${post.slug}/`}>
                  <span class="date">{fmtDate(post.data.date)}</span>
                  <div>
                    <p class="title">{post.data.title}</p>
                    <p class="summary">{post.data.summary}</p>
                  </div>
                </a>
              ))}
            </div>
          </section>
        )
      }
    </div>
  </main>
</Layout>
