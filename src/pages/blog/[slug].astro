---
import Layout from '../../layouts/Layout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

type Props = { post: CollectionEntry<'blog'> };

const { post } = Astro.props;
const { Content } = await post.render();
const base = import.meta.env.BASE_URL;

const fmtDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Layout
  title={`${post.data.title} — F. Dhani Achmad`}
  description={post.data.summary}
  activeNav="blog"
>
  <main class="page project-detail">
    <div class="container">
      <a class="nav-back" href={`${base}blog/`}>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="19" y1="12" x2="5" y2="12" />
          <polyline points="12 19 5 12 12 5" />
        </svg>
        ../blog
      </a>

      <header class="page-intro">
        <p class="kicker">{fmtDate(post.data.date)}</p>
        <h1>{post.data.title}</h1>
        <p class="lead">{post.data.summary}</p>
      </header>

      {
        post.data.tags.length > 0 && (
          <div class="stack-row">
            <span class="label">tags</span>
            {post.data.tags.map((t) => (
              <span class="chip-pill">{t}</span>
            ))}
          </div>
        )
      }

      <article class="project-body reveal">
        <Content />
      </article>
    </div>
  </main>
</Layout>
