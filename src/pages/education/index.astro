---
import Layout from '../../layouts/Layout.astro';
import { RESUME } from '../../data/resume';
const base = import.meta.env.BASE_URL;
---

<Layout
  title="Education — F. Dhani Achmad"
  description="Education history for F. Dhani Achmad — Universitas Gadjah Mada (Computer Science) and Richard Montgomery High School."
>
  <canvas id="cursor-canvas" aria-hidden="true"></canvas>

  <div class="paper">
    <main>
      <a class="nav-back" href={base}>
        <svg width="36" height="20" viewBox="0 0 36 20" aria-hidden="true">
          <path
            d="M34 10 C 22 6, 14 14, 4 9"
            fill="none"
            stroke="#1e2a5e"
            stroke-width="1.8"
            stroke-linecap="round"
          ></path>
          <path
            d="M10 4 L 4 9 L 10 14"
            fill="none"
            stroke="#1e2a5e"
            stroke-width="1.8"
            stroke-linecap="round"
            stroke-linejoin="round"
          ></path>
        </svg>
        back to the main page
      </a>

      <header class="intro">
        <h1>
          education
          <svg
            class="underline draw-on-scroll in-view"
            viewBox="0 0 420 22"
            preserveAspectRatio="none"
            aria-hidden="true"
          >
            <path
              d="M4 14 C 60 6, 140 18, 220 10 S 340 16, 416 12"
              fill="none"
              stroke="#d62828"
              stroke-width="3.5"
              stroke-linecap="round"
              style="--len: 600"
            ></path>
          </svg>
        </h1>
        <div class="role-tag">
          where I <em>learned</em> the basics — schools, certifications, the works.
        </div>
      </header>

      <!-- ====================== SCHOOLS ====================== -->
      <section class="schools reveal">
        <h2 class="mini-heading">schools</h2>
        <div class="education-list">
          {
            RESUME.education.map((edu) => (
              <div class="edu-row edu-row-detail">
                <span class="bracket" aria-hidden="true">
                  {'{'}
                </span>
                <div>
                  <p class="school">{edu.school}</p>
                  <p class="degree">{edu.degree}</p>
                </div>
              </div>
            ))
          }
        </div>
      </section>

      <!-- ====================== CERTIFICATIONS ====================== -->
      {
        RESUME.certifications.length > 0 && (
          <section class="certs reveal">
            <h2 class="mini-heading">certifications ✎</h2>
            <ul class="cert-list">
              {RESUME.certifications.map((c) => (
                <li>{c}</li>
              ))}
            </ul>
          </section>
        )
      }

      <!-- ====================== LANGUAGES ====================== -->
      <section class="langs reveal">
        <h2 class="mini-heading">languages</h2>
        <div class="lang-list">
          {
            RESUME.languages.map((l) => (
              <span class="lang-tag">{l}</span>
            ))
          }
        </div>
      </section>

      <!-- ====================== AWARDS ====================== -->
      <section class="awards reveal">
        <h2 class="mini-heading">honors & awards</h2>
        <ul class="award-list">
          {
            RESUME.awards.map((a) => (
              <li>
                <span class="award-year">{a.year}</span>
                <div>
                  <p class="award-title">{a.title}</p>
                  <p class="award-detail">{a.detail}</p>
                </div>
              </li>
            ))
          }
        </ul>
      </section>

      <footer class="reveal">
        <p class="signed">— signed, dhani ✎</p>
        <span class="signature">
          {RESUME.contact.email} · {new Date().getFullYear()}
        </span>
      </footer>
    </main>
  </div>

  <script is:inline>
    (function () {
      if (typeof IntersectionObserver === 'undefined') {
        document
          .querySelectorAll('.reveal, .draw-on-scroll')
          .forEach((el) => el.classList.add('in-view'));
        return;
      }
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('in-view');
              io.unobserve(entry.target);
            }
          });
        },
        { threshold: 0, rootMargin: '0px 0px 200px 0px' }
      );
      document
        .querySelectorAll('.reveal, .draw-on-scroll:not(.in-view)')
        .forEach((el) => io.observe(el));
    })();

    (function () {
      const canvas = document.getElementById('cursor-canvas');
      if (!canvas) return;
      if (window.matchMedia('(pointer: coarse)').matches) return;
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      const ctx = canvas.getContext('2d');
      const dpr = window.devicePixelRatio || 1;
      function size() {
        canvas.width = window.innerWidth * dpr;
        canvas.height = window.innerHeight * dpr;
        canvas.style.width = window.innerWidth + 'px';
        canvas.style.height = window.innerHeight + 'px';
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      }
      size();
      window.addEventListener('resize', size);
      let last = null;
      let lastTime = 0;
      window.addEventListener('mousemove', (e) => {
        const now = performance.now();
        const dt = now - lastTime;
        lastTime = now;
        if (last && dt < 80) {
          const speed = Math.hypot(e.clientX - last.x, e.clientY - last.y);
          if (speed > 1.5) {
            ctx.strokeStyle = 'rgba(60, 70, 110, 0.45)';
            ctx.lineWidth = Math.min(1.4, 0.6 + speed * 0.03);
            ctx.lineCap = 'round';
            ctx.beginPath();
            ctx.moveTo(last.x, last.y);
            ctx.lineTo(e.clientX, e.clientY);
            ctx.stroke();
          }
        }
        last = { x: e.clientX, y: e.clientY };
      });
      setInterval(() => {
        ctx.save();
        ctx.globalCompositeOperation = 'destination-out';
        ctx.fillStyle = 'rgba(0,0,0,0.045)';
        ctx.fillRect(0, 0, window.innerWidth, window.innerHeight);
        ctx.restore();
      }, 90);
    })();
  </script>
</Layout>
