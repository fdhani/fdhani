---
import Layout from '../../layouts/Layout.astro';
import { RESUME } from '../../data/resume';
const base = import.meta.env.BASE_URL;
---

<Layout
  title="Education — F. Dhani Achmad"
  description="Education history for F. Dhani Achmad — Universitas Gadjah Mada (Computer Science) and Richard Montgomery High School."
  activeNav="education"
>
  <main class="page">
    <div class="container">
      <a class="nav-back" href={base}>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="19" y1="12" x2="5" y2="12" />
          <polyline points="12 19 5 12 12 5" />
        </svg>
        ../
      </a>

      <header class="page-intro">
        <h1>Education</h1>
        <p class="lead">
          Schools, certifications, and a few awards from along the way.
        </p>
      </header>

      <section class="section reveal">
        <div class="section-head">
          <h2>schools</h2>
        </div>
        <div class="edu-list">
          {
            RESUME.education.map((edu) => (
              <div class="edu-row">
                <p class="school">{edu.school}</p>
                <p class="degree">{edu.degree}</p>
              </div>
            ))
          }
        </div>
      </section>

      {
        RESUME.certifications.length > 0 && (
          <section class="section reveal">
            <div class="section-head">
              <h2>certifications</h2>
            </div>
            <div class="chips">
              {RESUME.certifications.map((c) => (
                <span class="chip-pill">{c}</span>
              ))}
            </div>
          </section>
        )
      }

      <section class="section reveal">
        <div class="section-head">
          <h2>languages</h2>
        </div>
        <div class="chips">
          {RESUME.languages.map((l) => <span class="chip-pill">{l}</span>)}
        </div>
      </section>

      <section class="section reveal">
        <div class="section-head">
          <h2>awards</h2>
        </div>
        <ul class="award-list">
          {
            RESUME.awards.map((a) => (
              <li>
                <span class="award-year">{a.year}</span>
                <div>
                  <p class="award-title">{a.title}</p>
                  <p class="award-detail">{a.detail}</p>
                </div>
              </li>
            ))
          }
        </ul>
      </section>
    </div>
  </main>
</Layout>
