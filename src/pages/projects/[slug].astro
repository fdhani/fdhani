---
import Layout from '../../layouts/Layout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

type Props = { project: CollectionEntry<'projects'> };

const { project } = Astro.props;
const { Content } = await project.render();
const base = import.meta.env.BASE_URL;

const all = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
);
const others = all.filter((p) => p.slug !== project.slug).slice(0, 3);
---

<Layout
  title={`${project.data.name} — F. Dhani Achmad`}
  description={project.data.short}
  activeNav="projects"
>
  <main class="page project-detail">
    <div class="container">
      <a class="nav-back" href={`${base}projects/`}>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="19" y1="12" x2="5" y2="12" />
          <polyline points="12 19 5 12 12 5" />
        </svg>
        ../projects
      </a>

      <header class="page-intro">
        <p class="kicker">
          <span class="org">{project.data.org}</span> · {project.data.period}
        </p>
        <h1>{project.data.name}</h1>
        <p class="role-line">
          role: <span class="role">{project.data.role}</span>
        </p>
      </header>

      <div class="stack-row">
        <span class="label">stack</span>
        {project.data.stack.map((tech) => <span class="chip-pill">{tech}</span>)}
      </div>

      <article class="project-body reveal">
        <Content />
      </article>

      {
        project.data.link && (
          <p class="external-link reveal">
            <a href={project.data.link} target="_blank" rel="noopener">
              visit the live project
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="7" y1="17" x2="17" y2="7" />
                <polyline points="7 7 17 7 17 17" />
              </svg>
            </a>
          </p>
        )
      }

      <section class="related reveal">
        <div class="section-head">
          <h2>more projects</h2>
          <a class="more" href={`${base}projects/`}>all →</a>
        </div>
        <div class="cards">
          {
            others.map((p) => (
              <a class="card" href={`${base}projects/${p.slug}/`}>
                <div class="head">
                  <h3 class="name">{p.data.name}</h3>
                  <svg class="arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <line x1="7" y1="17" x2="17" y2="7" />
                    <polyline points="7 7 17 7 17 17" />
                  </svg>
                </div>
                <p class="desc">{p.data.short}</p>
                <div class="stack">
                  <span class="chip">{p.data.org}</span>
                  <span class="chip">{p.data.period}</span>
                </div>
              </a>
            ))
          }
        </div>
      </section>
    </div>
  </main>
</Layout>
