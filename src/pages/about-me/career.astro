---
import AboutLayout from '../../layouts/AboutLayout.astro';
import { RESUME } from '../../data/resume';

const yearRange = (when: string) => {
  const parts = when.split(/[–-]/).map((p) => p.trim());
  const grabYear = (s: string) => {
    const m = s.match(/(20\d{2}|19\d{2})/);
    if (m) return m[1];
    if (/present/i.test(s)) return 'now';
    return s;
  };
  const start = grabYear(parts[0]);
  const end = grabYear(parts[1] || '');
  if (!end) return start;
  if (start === end) return start;
  return `${start} – ${end === 'now' ? 'now' : end.slice(-2)}`;
};
---

<AboutLayout
  activeTab="career"
  title="Career — F. Dhani Achmad"
  description="Career history of F. Dhani Achmad — Omni HR, 99 Group, Tokopedia, and more."
>
  <section class="reveal">
    <div class="section-head">
      <h2>experience</h2>
    </div>
    <div class="timeline">
      {
        RESUME.experience.map((e) => (
          <div class="exp">
            <div class="when">
              {yearRange(e.when)}
              <span class="loc">{e.loc}</span>
            </div>
            <div class="body">
              <p class="role">{e.role}</p>
              <p class="org">@ {e.org}</p>
              <ul class="bullets">
                {e.bullets.map((b) => (
                  <li>{b}</li>
                ))}
              </ul>
            </div>
          </div>
        ))
      }
    </div>
  </section>
</AboutLayout>
