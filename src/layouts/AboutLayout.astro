---
import Layout from './Layout.astro';
import { RESUME } from '../data/resume';

interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
const base = import.meta.env.BASE_URL;

const tabs: { key: string; label: string }[] = [
  { key: 'experience', label: 'experience' },
  { key: 'education', label: 'education' },
  { key: 'awards', label: 'awards' },
];
---

<Layout
  title={title ?? `About me — F. Dhani Achmad`}
  description={
    description ??
    'About F. Dhani Achmad — frontend engineer based in West Java, Indonesia. Experience, schools, and awards.'
  }
  activeNav="about-me"
>
  <main class="page">
    <div class="container">
      <a class="nav-back" href={base}>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="19" y1="12" x2="5" y2="12" />
          <polyline points="12 19 5 12 12 5" />
        </svg>
        ../
      </a>

      <header class="page-intro about-intro">
        <h1>About me</h1>
        <p class="lead">
          Frontend engineer with a designer's eye and an AI tinkerer's curiosity.
          The last eight years have been spent shipping product surfaces at
          Tokopedia, 99 Group, and now Omni HR — usually somewhere between
          design systems and platform work.
        </p>

        <div class="hero meta about-meta">
          <span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" />
              <circle cx="12" cy="10" r="3" />
            </svg>
            {RESUME.location}
          </span>
          <span>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="10" />
              <polyline points="12 6 12 12 16 14" />
            </svg>
            8+ years in frontend
          </span>
        </div>
      </header>

      <nav class="about-tabs" aria-label="About sections" id="about-tabs">
        {
          tabs.map((t) => (
            <a
              href={`#${t.key}`}
              data-tab={t.key}
              aria-controls={`panel-${t.key}`}
            >
              {t.label}
            </a>
          ))
        }
      </nav>

      <div class="about-panels" id="about-panels" data-active-tab="experience">
        <slot />
      </div>
    </div>
  </main>

  <script is:inline>
    (function () {
      var tabsNav = document.getElementById('about-tabs');
      var panels = document.getElementById('about-panels');
      if (!tabsNav || !panels) return;

      var valid = ['experience', 'education', 'awards'];

      function setActive(key, opts) {
        opts = opts || {};
        if (valid.indexOf(key) === -1) key = 'experience';
        panels.setAttribute('data-active-tab', key);
        tabsNav.querySelectorAll('a').forEach(function (a) {
          var isActive = a.getAttribute('data-tab') === key;
          if (isActive) {
            a.classList.add('active');
            a.setAttribute('aria-current', 'page');
          } else {
            a.classList.remove('active');
            a.removeAttribute('aria-current');
          }
        });
        if (opts.updateHash !== false) {
          var newHash = '#' + key;
          if (window.location.hash !== newHash) {
            history.replaceState(null, '', newHash);
          }
        }
      }

      function readHash() {
        return (window.location.hash || '').replace(/^#/, '');
      }

      // initial
      setActive(readHash() || 'experience', { updateHash: false });

      // tab click → no full reload
      tabsNav.addEventListener('click', function (e) {
        var a = e.target.closest('a[data-tab]');
        if (!a) return;
        e.preventDefault();
        setActive(a.getAttribute('data-tab'));
      });

      // back/forward
      window.addEventListener('hashchange', function () {
        setActive(readHash() || 'experience', { updateHash: false });
      });
    })();
  </script>
</Layout>
