---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  activeNav?: 'home' | 'about-me' | 'projects' | 'blog';
}

const {
  title = 'F. Dhani Achmad — Frontend Engineer',
  description = 'Frontend Engineer based in West Java, Indonesia. Currently at Omni HR; previously Tokopedia and 99 Group.',
  activeNav,
} = Astro.props;

const base = import.meta.env.BASE_URL;
const nav: { key: NonNullable<Props['activeNav']>; href: string; label: string }[] = [
  { key: 'home', href: base, label: 'home' },
  { key: 'about-me', href: `${base}about-me/`, label: 'about me' },
  { key: 'projects', href: `${base}projects/`, label: 'projects' },
  { key: 'blog', href: `${base}blog/`, label: 'blog' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="F. Dhani Achmad" />
    <meta name="theme-color" content="#0b0d10" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#fafafa" media="(prefers-color-scheme: light)" />
    <meta name="generator" content={Astro.generator} />
    <link
      rel="icon"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='6' fill='%230b0d10'/%3E%3Ctext x='16' y='22' font-family='JetBrains Mono,monospace' font-size='17' font-weight='700' fill='%235eead4' text-anchor='middle'%3Efd%3C/text%3E%3C/svg%3E"
    />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <meta property="og:type" content="profile" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    <title>{title}</title>

    <script is:inline>
      // Set theme before paint to avoid FOUC.
      (function () {
        try {
          var stored = localStorage.getItem('theme');
          var theme = stored || 'dark';
          document.documentElement.setAttribute('data-theme', theme);
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      <div class="inner">
        <a class="site-brand" href={base} aria-label="Home">
          <span class="dot" aria-hidden="true"></span>
          fdhani
        </a>

        <nav class="site-nav" aria-label="Primary">
          {
            nav.map((item) => (
              <a
                href={item.href}
                aria-current={activeNav === item.key ? 'page' : undefined}
              >
                {item.label}
              </a>
            ))
          }
          <button
            type="button"
            class="theme-toggle js-theme-toggle"
            aria-label="Toggle color theme"
            title="Toggle theme"
          >
            <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
            </svg>
            <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="4" />
              <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
            </svg>
          </button>
        </nav>
      </div>
    </header>

    <slot />

    <footer class="site-footer">
      <div class="inner">
        <span>© {new Date().getFullYear()} F. Dhani Achmad</span>
        <span class="links">
          <a href="mailto:fachran.dhani@gmail.com">email</a>
          <a href="https://github.com/dhani48" target="_blank" rel="noopener">github</a>
          <a href="https://www.linkedin.com/in/fachran-dhani" target="_blank" rel="noopener">linkedin</a>
        </span>
      </div>
    </footer>

    <!-- ================ MOBILE BOTTOM NAV ================ -->
    <div class="mobile-nav-scrim" id="mobile-nav-scrim" aria-hidden="true"></div>

    <div class="mobile-nav-panel" id="mobile-nav-panel" role="dialog" aria-modal="true" aria-label="Site navigation" aria-hidden="true">
      <nav class="mobile-nav-links" aria-label="Mobile primary">
        {
          nav.map((item) => (
            <a
              href={item.href}
              aria-current={activeNav === item.key ? 'page' : undefined}
            >
              <span class="label">{item.label}</span>
              <svg class="arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="7" y1="17" x2="17" y2="7" />
                <polyline points="7 7 17 7 17 17" />
              </svg>
            </a>
          ))
        }
      </nav>
      <div class="mobile-nav-divider" aria-hidden="true"></div>
      <button
        type="button"
        class="mobile-nav-theme js-theme-toggle"
        aria-label="Toggle color theme"
      >
        <span class="label">theme</span>
        <span class="mobile-nav-theme-icons">
          <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
          </svg>
          <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="4" />
            <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
          </svg>
        </span>
      </button>
    </div>

    <button
      type="button"
      class="mobile-nav-toggle"
      id="mobile-nav-toggle"
      aria-controls="mobile-nav-panel"
      aria-expanded="false"
    >
      <span class="dot" aria-hidden="true"></span>
      <span class="text">menu</span>
      <svg class="chev" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="6 15 12 9 18 15" />
      </svg>
    </button>

    <script is:inline>
      // ---------- theme toggle (works for any .js-theme-toggle button) ----------
      (function () {
        var buttons = document.querySelectorAll('.js-theme-toggle');
        buttons.forEach(function (btn) {
          btn.addEventListener('click', function () {
            var current = document.documentElement.getAttribute('data-theme') || 'dark';
            var next = current === 'dark' ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', next);
            try {
              localStorage.setItem('theme', next);
            } catch (e) {}
          });
        });
      })();

      // ---------- reveal on scroll ----------
      (function () {
        if (typeof IntersectionObserver === 'undefined') {
          document.querySelectorAll('.reveal').forEach(function (el) {
            el.classList.add('in-view');
          });
          return;
        }
        var io = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add('in-view');
                io.unobserve(entry.target);
              }
            });
          },
          { threshold: 0, rootMargin: '0px 0px 100px 0px' }
        );
        document.querySelectorAll('.reveal').forEach(function (el) {
          io.observe(el);
        });
      })();

      // ---------- mobile bottom nav ----------
      (function () {
        var toggle = document.getElementById('mobile-nav-toggle');
        var panel = document.getElementById('mobile-nav-panel');
        var scrim = document.getElementById('mobile-nav-scrim');
        if (!toggle || !panel || !scrim) return;

        function setOpen(open) {
          document.body.dataset.mobileNav = open ? 'open' : '';
          toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
          panel.setAttribute('aria-hidden', open ? 'false' : 'true');
          scrim.setAttribute('aria-hidden', open ? 'false' : 'true');
        }

        toggle.addEventListener('click', function () {
          var open = document.body.dataset.mobileNav !== 'open';
          setOpen(open);
        });
        scrim.addEventListener('click', function () { setOpen(false); });

        // Close on link tap (don't intercept theme toggle).
        panel.querySelectorAll('a').forEach(function (a) {
          a.addEventListener('click', function () { setOpen(false); });
        });

        // Close on Escape.
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape' && document.body.dataset.mobileNav === 'open') {
            setOpen(false);
          }
        });

        // Close on scroll (debounced).
        var scrollTimer = null;
        window.addEventListener(
          'scroll',
          function () {
            if (document.body.dataset.mobileNav !== 'open') return;
            if (scrollTimer) return;
            scrollTimer = setTimeout(function () {
              scrollTimer = null;
              setOpen(false);
            }, 60);
          },
          { passive: true }
        );
      })();
    </script>
  </body>
</html>
